// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int         @id @default(autoincrement())
  name      String
  email     String      @unique
  password  String
  createdAt DateTime    @default(now())
  perguntas Perguntas[]
  respostas Respostas[]
}

model Perguntas {
  id          Int    @id @default(autoincrement())
  title       String
  description String

  userId Int
  user   User @relation(fields: [userId], references: [id])

  respostas Respostas[]

  createdAt DateTime @default(now())
}

model Respostas {
  id      Int    @id @default(autoincrement())
  content String

  userId Int
  user   User @relation(fields: [userId], references: [id])

  questionId Int
  perguntas  Perguntas @relation(fields: [questionId], references: [id])

  createdAt DateTime @default(now())
}
